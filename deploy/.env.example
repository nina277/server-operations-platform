# このファイルを .env にコピーして値を設定する
#   cp .env.example .env
# .env はGit管理しない。実際の値(パスワード等)をコミットしないこと。

# nginxが外部へ公開するHTTPポート
HTTP_PORT=8080

# ASP.NET Core実行環境 (Production / Development)
ASPNETCORE_ENVIRONMENT=Production

# タイムゾーン
TZ=Asia/Tokyo

# MySQL接続情報(ダミー値。必ず変更すること)
MYSQL_ROOT_PASSWORD=dummy-root-password-change-me
MYSQL_DATABASE=server_operations
MYSQL_USER=serverops
MYSQL_PASSWORD=dummy-password-change-me

# JWT署名鍵(32文字以上のランダム文字列。必ず変更すること)
# 例: openssl rand -base64 48 で生成する
JWT_SIGNING_KEY=dummy-jwt-signing-key-at-least-32-characters-change-me

# 初期管理者(ユーザーが1人もいない場合の初回起動時のみ作成される)
# パスワードは12文字以上。作成後はこの値を .env から消してよい
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=dummy-admin-password-change-me
